[Unit]
Description=rssBridge RSS aggregator
After=network.target

[Service]
Type=simple
User=rssbridge
Group=rssbridge
WorkingDirectory=/opt/rssbridge
ExecStart=/opt/rssbridge/rssBridge -db /var/lib/rssbridge/rssbridge.db
Restart=on-failure
RestartSec=5

# Harden the service
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/rssbridge

[Install]
WantedBy=multi-user.target
